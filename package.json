{
  "name": "ya-disk",
  "version": "5.0.0",
  "description": "Yandex Disk API Library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/RomiC/ya-disk.git"
  },
  "author": "Roman Charugin <romic+github@fastmail.com> (https://github.com/RomiC)",
  "contributors": [
    "Roman Charugin <romic+github@fastmail.com> (https://github.com/RomiC)",
    "Mustafa Yazar <myazarc@gmail.com> (https://github.com/myazarc)",
    "Alexey Gerasimov <lokomot476@gmail.com> (https://github.com/fan-tom)"
  ],
  "license": "MIT",
  "engines": {
    "node": ">= 22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/markdown": "8.0.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "esbuild": "0.25.4",
    "c8": "10.1.3",
    "eslint-plugin-prettier": "5.5.5",
    "follow-redirects": "1.16.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "prettier": "3.8.3"
  },
  "bugs": {
    "url": "https://github.com/RomiC/ya-disk/issues"
  },
  "homepage": "https://github.com/RomiC/ya-disk#readme",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "directories": {
    "doc": "./README.md",
    "example": "./examples",
    "lib": "./lib",
    "test": "./tests"
  },
  "scripts": {
    "build": "npm run build:clean && npm run build:esm && npm run build:cjs",
    "build:clean": "node -e \"import('node:fs').then(({rmSync,mkdirSync})=>{rmSync('dist',{recursive:true,force:true});mkdirSync('dist/lib',{recursive:true});});\"",
    "build:esm": "esbuild index.js lib/*.js --platform=node --format=esm --target=node22 --outdir=dist --outbase=.",
    "build:cjs": "esbuild index.js lib/*.js --platform=node --format=cjs --target=node22 --outdir=dist --outbase=. --out-extension:.js=.cjs",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "smoke": "node ./scripts/smoke-cjs.cjs && node ./scripts/smoke-esm.mjs",
    "test": "node --test tests/*.spec.js",
    "test:watch": "node --watch --test tests/*.spec.js",
    "test:coverage": "c8 --all --include='lib/*.js' --include='index.js' --exclude='lib/constants.js' --reporter=text --reporter=lcov --reporter=clover node --test tests/*.spec.js",
    "prepare": "husky install",
    "prepack": "npm run build && npm run smoke"
  },
  "keywords": [
    "yandex",
    "disk",
    "api"
  ],
  "lint-staged": {
    "+(examples|lib|tests)/*.{js,mjs}": "npm run lint:fix",
    "+(index.js|scripts/*.{cjs,mjs})": "npm run lint:fix"
  }
}
