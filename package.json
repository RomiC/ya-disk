{
  "name": "ya-disk",
  "version": "4.1.0",
  "description": "Yandex Disk API Library",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/RomiC/ya-disk.git"
  },
  "author": "Roman Charugin <romic+github@fastmail.com> (https://github.com/RomiC)",
  "contributors": [
    "Roman Charugin <romic+github@fastmail.com> (https://github.com/RomiC)",
    "Mustafa Yazar <myazarc@gmail.com> (https://github.com/myazarc)",
    "Alexey Gerasimov <lokomot476@gmail.com> (https://github.com/fan-tom)"
  ],
  "license": "MIT",
  "engines": {
    "node": ">= 22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/markdown": "8.0.1",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "c8": "10.1.3",
    "eslint-plugin-prettier": "5.5.5",
    "follow-redirects": "1.16.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "expect": "30.2.0",
    "jest-mock": "30.2.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1"
  },
  "bugs": {
    "url": "https://github.com/RomiC/ya-disk/issues"
  },
  "homepage": "https://github.com/RomiC/ya-disk#readme",
  "directories": {
    "doc": "./README.md",
    "example": "./examples",
    "lib": "./lib",
    "test": "./tests"
  },
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "node --require ./tests/node-test-setup.cjs --test tests/*.spec.js",
    "test:watch": "node --watch --require ./tests/node-test-setup.cjs --test tests/*.spec.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=clover --exclude=lib/constants.js --exclude=lib/typedefs.js node --require ./tests/node-test-setup.cjs --test tests/*.spec.js",
    "prepare": "husky install"
  },
  "keywords": [
    "yandex",
    "disk",
    "api"
  ],
  "lint-staged": {
    "+(examples|lib|tests)/*.js": "npm run lint:fix",
    "+index.js": "npm run lint:fix"
  }
}
